# Backend
SPACEX_API_BASE=https://api.spacexdata.com
REDIS_URL=redis://localhost:6379/0

# Cache TTLs (seconds)
ROCKETS_TTL=86400
LAUNCHES_TTL=120
STARLINK_TTL=300
DASHBOARD_TTL=300

# SpaceX client
SPACEX_TIMEOUT=10
SPACEX_RETRIES=2

# AI (optional — get a free key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend
VITE_API_URL=/api
